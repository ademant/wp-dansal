# Copy to .env and fill in for `make deploy`. Not used by zip/build/pot.

# wp-content/plugins directory of your local WordPress install.
WP_PLUGIN_DIR=/path/to/wordpress/wp-content/plugins

# user:group that should own the deployed plugin files (typically the
# webserver's user, so PHP can read/write without permission errors).
WP_OWNER=www-data:www-data
